{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FPSBooster",
  "version": "1.0.0",
  "identifier": "com.fpsbooster.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FPSBooster",
        "width": 1280,
        "height": 820,
        "minWidth": 1020,
        "minHeight": 680,
        "center": true,
        "decorations": false,
        "shadow": true
      },
      {
        "label": "overlay",
        "title": "FPS Overlay",
        "url": "overlay.html",
        "width": 240,
        "height": 96,
        "x": 24,
        "y": 24,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "closable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
